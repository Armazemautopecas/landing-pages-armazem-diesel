# Tracking — todas opcionais. Setar SOMENTE as que o Vinicius decidir usar.
# Sem nenhuma var setada, a LP roda 100% sem tracking (estado atual de produção).
#
# Setar no Vercel em: Project Settings → Environment Variables
# Após colar, redeploy é automático (commit ou Redeploy manual no dashboard).

# Google Analytics 4
# Onde achar: GA4 → Admin → Streams → ID de medição (G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_ID=

# Google Ads (Conversion Tracking)
# Onde achar: Google Ads → Ferramentas → Conversões → Tag → AW-XXXXXXXXX
NEXT_PUBLIC_GADS_ID=

# Google Tag Manager (gerencia GA4 + Ads + outras tags via UI do GTM)
# Onde achar: GTM → Admin → ID do contêiner (GTM-XXXXXXX)
# IMPORTANTE: se GTM_ID estiver setado, GA4_ID e GADS_ID acima são IGNORADOS
# (configura GA4 e Ads dentro do próprio GTM em vez de aqui).
NEXT_PUBLIC_GTM_ID=
